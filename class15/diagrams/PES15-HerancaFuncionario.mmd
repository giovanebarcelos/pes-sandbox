%% PES15 - Diagrama de Classes: Herança Funcionario
%% Aula 15: Diagrama de Classes e Orientação a Objetos
%% Projeto e Engenharia de Software - Prof. Giovane Barcelos
%% Mermaid compatível com PlantUML (https://plantuml.com/):
%% para renderizar no PlantUML, envolva o conteúdo abaixo em @startmermaid ... @endmermaid.
classDiagram
    class Funcionario {
        <<abstract>>
        -String nome
        -double salarioBase
        +getNome() String
        +getSalarioBase() double
        +calcularSalario()* double
    }
    class Desenvolvedor {
        -String linguagem
        +calcularSalario() double
    }
    class Gerente {
        -double bonus
        +calcularSalario() double
    }
    Funcionario <|-- Desenvolvedor
    Funcionario <|-- Gerente
