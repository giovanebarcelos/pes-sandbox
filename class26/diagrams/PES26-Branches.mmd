%% PES26 - Branches no Git
%% Aula 26: Fluxos de Trabalho com Git e Colaboração
%% Projeto e Engenharia de Software - Prof. Giovane Barcelos
%% Mermaid compatível com PlantUML (https://plantuml.com/):
%% para renderizar no PlantUML, envolva o conteúdo abaixo em @startmermaid ... @endmermaid.
gitGraph
    commit id: "init"
    commit id: "setup"
    branch feature/login
    checkout feature/login
    commit id: "add login"
    commit id: "add tests"
    checkout main
    merge feature/login
    branch feature/pagamento
    checkout feature/pagamento
    commit id: "add pagamento"
    checkout main
    merge feature/pagamento
    commit id: "release v1.0"
