%% PES18 - Mapa Mental dos 22 Padrões GoF (Gang of Four)
%% Aula 18: Princípios de Projeto e Padrões Arquiteturais
%% Projeto e Engenharia de Software - Prof. Giovane Barcelos
%% Mermaid compatível com PlantUML (https://plantuml.com/):
%% para renderizar no PlantUML, envolva o conteúdo abaixo em @startmermaid ... @endmermaid.
mindmap
  root("🎯 GoF Design Patterns")
    Creational["🔷 Padrões de Criação"]
      Singleton["Singleton\nInstância única global"]
      FactoryMethod["Factory Method\nCriação delegada a subclasses"]
      AbstractFactory["Abstract Factory\nFamílias de objetos relacionados"]
      Builder["Builder\nConstrução passo a passo"]
      Prototype["Prototype\nClonagem de instâncias"]
    Structural["🔶 Padrões Estruturais"]
      Adapter["Adapter\nInterface incompatível → compatível"]
      Bridge["Bridge\nSepara abstração de implementação"]
      Composite["Composite\nÁrvore de objetos (parte-todo)"]
      Decorator["Decorator\nAdiciona responsabilidades dinâmicas"]
      Facade["Facade\nFachada simplificada p/ subsistema"]
      Flyweight["Flyweight\nCompartilhamento eficiente"]
      Proxy["Proxy\nSubstituto/representante controlado"]
    Behavioral["🔵 Padrões Comportamentais"]
      ChainOfResp["Chain of Responsibility\nCadeia de handlers"]
      Command["Command\nRequisição encapsulada como objeto"]
      Interpreter["Interpreter\nGramática e interpretação"]
      Iterator["Iterator\nPercorre coleção sem expor estrutura"]
      Mediator["Mediator\nCoordena comunicação entre objetos"]
      Memento["Memento\nSalva/restaura estado interno"]
      Observer["Observer\nNotifica mudanças a dependentes"]
      State["State\nComportamento varia por estado"]
      Strategy["Strategy\nFamília de algoritmos intercambiáveis"]
      TemplateMethod["Template Method\nEsqueleto de algoritmo em superclasse"]
      Visitor["Visitor\nOperação sobre elementos de estrutura"]
  style root fill:#2563EB,color:#FFF
  style Creational fill:#059669,color:#FFF
  style Structural fill:#EA580C,color:#FFF
  style Behavioral fill:#7C3AED,color:#FFF
