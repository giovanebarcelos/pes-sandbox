flowchart TD
    A["git init / clone"] --> B["Editar arquivos"]
    B --> C["git add"]
    C --> D["git commit -m 'mensagem'"]
    D --> E{"Mais mudanças?"}
    E -->|Sim| B
    E -->|Não| F["git push"]
    F --> G["git log"]
    G --> H["Colaborar: pull request"]
