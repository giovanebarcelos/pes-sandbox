%% PES17 - Casos de Uso: Mini-Sistema Locadora
%% Aula 17: Projeto Parcial — Modelagem UML + Implementação OO
%% Projeto e Engenharia de Software - Prof. Giovane Barcelos
%% Mermaid compatível com PlantUML (https://plantuml.com/):
%% para renderizar no PlantUML, envolva o conteúdo abaixo em @startmermaid ... @endmermaid.
flowchart TD
    subgraph Sistema["📦 Locadora de Veículos"]
        UC1["UC01: Cadastrar veículo"]
        UC2["UC02: Listar veículos disponíveis"]
        UC3["UC03: Alugar veículo"]
        UC4["UC04: Devolver veículo"]
        UC5["UC05: Calcular valor da locação"]
    end
    ATOR1["👤 Atendente"] --> UC1
    ATOR1 --> UC2
    ATOR1 --> UC3
    ATOR1 --> UC4
    ATOR2["👤 Cliente"] --> UC2
    ATOR2 --> UC3
    UC3 -.->|«include»| UC5
    UC4 -.->|«include»| UC5
    style Sistema fill:#F0F4F8,stroke:#2563EB
    style ATOR1 fill:#7C3AED,color:#FFF
    style ATOR2 fill:#059669,color:#FFF
