flowchart TD
    Core["⚙️ Microkernel (Core)\nFuncionalidades mínimas\nessenciais"] --> Registry["🔌 Plugin Registry\n(gerencia extensões)"]
    Registry --> P1["🧩 Plugin PDF\nExportação em PDF"]
    Registry --> P2["🧩 Plugin CSV\nExportação em CSV"]
    Registry --> P3["🧩 Plugin Email\nNotificação por e-mail"]
    Registry --> P4["🧩 Plugin SMS\nNotificação por SMS"]
    P1 -.->|"implementa"| Interface["📋 IExportPlugin\n(contrato do plugin)"]
    P2 -.->|"implementa"| Interface
    P3 -.->|"implementa"| Interface2["📋 INotifyPlugin\n(contrato do plugin)"]
    P4 -.->|"implementa"| Interface2
    Interface --- Core
    Interface2 --- Core
