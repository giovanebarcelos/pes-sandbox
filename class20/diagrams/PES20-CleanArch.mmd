%% PES20 - Clean Architecture (Círculos Concêntricos)
%% Aula 20: Clean Architecture, Hexagonal e Onion
%% Projeto e Engenharia de Software - Prof. Giovane Barcelos
%% Mermaid compatível com PlantUML (https://plantuml.com/):
%% para renderizar no PlantUML, envolva o conteúdo abaixo em @startmermaid ... @endmermaid.
flowchart TD
    subgraph Core["🎯 Entidades (Domínio)"]
        E["Regras de negócio\nmais abstratas"]
    end
    subgraph UC["📋 Casos de Uso"]
        U["Orquestração do\ndomínio"]
    end
    subgraph Adapters["🔌 Adaptadores"]
        AD["Controllers,\nGateways,\nPresenters"]
    end
    subgraph Ext["🌐 Frameworks"]
        EX["Web, DB, UI\n(detalhes)"]
    end
    Ext --> Adapters --> UC --> Core
    style Core fill:#EF4444,color:#FFF
    style UC fill:#D97706,color:#FFF
    style Adapters fill:#2563EB,color:#FFF
    style Ext fill:#64748B,color:#FFF
