%% PES20 - Onion Architecture (Camadas Concêntricas)
%% Aula 20: Clean Architecture, Hexagonal e Onion
%% Projeto e Engenharia de Software - Prof. Giovane Barcelos
%% Mermaid compatível com PlantUML (https://plantuml.com/):
%% para renderizar no PlantUML, envolva o conteúdo abaixo em @startmermaid ... @endmermaid.
flowchart TD
    subgraph Core["🎯 Domain (Centro)"]
        E["Entidades\nValue Objects\nInterfaces repositório"]
    end
    subgraph App["📋 Application"]
        S["Serviços de aplicação\nCasos de Uso\nDTOs"]
    end
    subgraph Infra["🔌 Infrastructure"]
        I["Repositórios concretos\nORM, APIs externas\nServiços de e-mail"]
    end
    subgraph Pres["🌐 Presentation"]
        P["Controllers\nViews / APIs\nCLI / Web"]
    end
    Pres --> App --> Core
    Infra --> Core
    Pres -.->|"resolvida via DI\n(não é dependência de compilação)"| Infra
    style Core fill:#EF4444,color:#FFF
    style App fill:#D97706,color:#FFF
    style Infra fill:#2563EB,color:#FFF
    style Pres fill:#64748B,color:#FFF
