flowchart TD
    subgraph I1["Incremento 1 — Núcleo"]
        A1["Análise"] --> B1["Projeto"] --> C1["Implementação"] --> D1["Entrega v1"]
    end
    subgraph I2["Incremento 2 — Funcionalidades"]
        A2["Análise"] --> B2["Projeto"] --> C2["Implementação"] --> D2["Entrega v2"]
    end
    subgraph I3["Incremento 3 — Refinamento"]
        A3["Análise"] --> B3["Projeto"] --> C3["Implementação"] --> D3["Entrega v3"]
    end
    D1 --> A2
    D2 --> A3
    style I1 fill:#2563EB,color:#FFF
    style I2 fill:#EA580C,color:#FFF
    style I3 fill:#059669,color:#FFF
