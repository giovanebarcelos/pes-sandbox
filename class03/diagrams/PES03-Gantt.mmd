%% PES03 - Gráfico de Gantt Simplificado
%% Aula 03: Planejamento — Escopo, Prazo, Custo e Qualidade
%% Projeto e Engenharia de Software - Prof. Giovane Barcelos
%% Mermaid compatível com PlantUML (https://plantuml.com/):
%% para renderizar no PlantUML, envolva o conteúdo abaixo em @startmermaid ... @endmermaid.
gantt
    title Cronograma — Sistema de Biblioteca
    dateFormat  YYYY-MM-DD
    section Gerenciamento
    Plano de Projeto       :a1, 2025-08-01, 7d
    Reuniões semanais      :a2, 2025-08-01, 56d
    section Requisitos
    Entrevistas             :b1, 2025-08-08, 7d
    Documento de Requisitos :b2, after b1, 10d
    section Desenvolvimento
    Back-end                :c1, after b2, 21d
    Front-end               :c2, after b2, 21d
    Banco de Dados          :c3, after b2, 14d
    section Testes
    Testes Unitários        :d1, after c1, 7d
    Testes Integrados       :d2, after d1, 7d
    section Entrega
    Implantação             :e1, after d2, 3d
